# LexNet Frontend Environment Variables
# All variables must be prefixed with VITE_ to be accessible in the browser.

# Backend GraphQL URL (Apollo Client endpoint)
VITE_API_URL=http://localhost:4000/graphql

# Backend REST API URL (for hardware auth, verification, health endpoints)
VITE_REST_API_URL=http://localhost:4000/api

# Application display name
VITE_APP_NAME=LexNet
