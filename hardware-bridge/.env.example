# Serial port for STM32 UART connection (COM3 on Windows, /dev/ttyACM0 on Linux)
# Optional when using --tcp simulator mode.
SERIAL_PORT=COM3

# UART baud rate — must match firmware setting (57600 8N1)
BAUD_RATE=57600

# HS256 JWT signing key — MUST match backend JWT_SECRET (minimum 32 chars)
JWT_SECRET=change-me-32-char-minimum-secret

# Backend API base URL for hardware auth endpoint
API_URL=http://localhost:4000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
BRIDGE_LOG_LEVEL=INFO

# Maximum age of packet timestamp in seconds before rejection
TIMESTAMP_TOLERANCE_SEC=30

# Minimum fingerprint match score (0-100) to accept authentication
MIN_FINGER_SCORE=60
