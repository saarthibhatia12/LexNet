# ============================================================================
# LexNet Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values before running the server.
# ============================================================================

# --- Server ---
PORT=4000                                            # Express server port
NODE_ENV=development                                 # Environment: development | production | test

# --- Authentication ---
JWT_SECRET=change-me-32-char-minimum-secret          # HS256 signing key (min 32 characters, MUST match hardware-bridge)
JWT_EXPIRY=1h                                        # Session token TTL (e.g. 1h, 30m, 7d)

# --- Hyperledger Fabric ---
FABRIC_CHANNEL=lexnet-channel                        # Fabric channel name
FABRIC_CHAINCODE=lexnet-cc                           # Deployed chaincode name
FABRIC_WALLET_PATH=./wallet                          # Filesystem path to identity wallet
FABRIC_CONNECTION_PROFILE=./connection-org1.json     # Path to Fabric connection profile JSON
FABRIC_MSP_ID=GovtOrgMSP                            # Organisation MSP ID

# --- IPFS ---
IPFS_API_URL=http://localhost:5001                   # IPFS Kubo API endpoint
IPFS_GATEWAY_URL=http://localhost:8080               # IPFS HTTP gateway

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687                      # Neo4j Bolt protocol endpoint
NEO4J_USER=neo4j                                     # Neo4j username
NEO4J_PASSWORD=lexnet-neo4j-pass                     # Neo4j password

# --- Encryption ---
AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef  # 256-bit AES key as 64 hex chars

# --- NLP Service ---
NLP_SERVICE_URL=http://localhost:5500                # Python NLP Flask service URL

# --- Verification ---
VERIFICATION_BASE_URL=http://localhost:3000           # Public URL for QR verification links

# --- Logging ---
LOG_LEVEL=info                                       # Winston log level: error | warn | info | debug | silly

# --- File Uploads ---
MAX_FILE_SIZE_MB=50                                  # Maximum upload file size in MB
